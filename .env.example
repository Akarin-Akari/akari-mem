# akari-mem environment configuration
# Copy this file to .env and customize for your setup

# Data directory (SQLite + ChromaDB storage)
# Default: ./data (relative to project root)
AKARI_MEM_DATA_DIR=./data

# Model cache directory (HuggingFace models)
# Default: ~/.cache/huggingface
# HF_HOME=~/.cache/huggingface

# HuggingFace mirror (useful in China)
# HF_ENDPOINT=https://hf-mirror.com

# Extra Python libs path (if packages installed via pip --target)
# AKARI_MEM_LIBS=/path/to/python-libs

# API server port
# AKARI_MEM_PORT=37800
